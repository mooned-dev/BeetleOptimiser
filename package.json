{
  "name": "beetleoptimiser",
  "version": "0.2.0",
  "description": "Beetle Optimiser - open-source Windows system optimizer (deep disk cleaner, defrag, registry repair, startup manager, uninstall manager, Win10 protector, etc.)",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && electron .",
    "package": "npm run build && electron-builder --win portable"
  },
  "keywords": [
    "windows",
    "optimizer",
    "cleanup",
    "defrag",
    "registry",
    "startup",
    "electron",
    "powershell",
    "system-utility",
    "open-source"
  ],
  "homepage": "https://github.com/orchords-com/BeetleOptimiser",
  "bugs": "https://github.com/orchords-com/BeetleOptimiser/issues",
  "author": "ORCHIDS.COM <crm@orchords.com>",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "30.5.1",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.orchords.beetleoptimiser",
    "productName": "BeetleOptimiser",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "main.js",
      "src/preload.js",
      "scripts/**/*",
      "dist/index.html",
      "dist/assets/**/*",
      "build/icon.ico",
      "package.json",
      "!dist/win-unpacked/**"
    ],
    "asarUnpack": [
      "scripts/**/*"
    ]
  }
}
