{
  "name": "beetleoptimiser",
  "version": "1.0.0",
  "description": "Beetle Optimiser - open-source Windows system optimizer (deep disk cleaner, defrag, registry repair, startup manager, uninstall manager, Win10 protector, etc.)",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && electron .",
    "test": "node --test tests/*.test.js",
    "test:watch": "node --test --watch tests/*.test.js",
    "package": "npm run build && electron-builder --win portable",
    "package:all": "npm run build && electron-builder --win portable nsis"
  },
  "keywords": [
    "windows",
    "optimizer",
    "cleanup",
    "defrag",
    "registry",
    "startup",
    "electron",
    "powershell",
    "system-utility",
    "open-source"
  ],
  "homepage": "https://github.com/ORCHORDS/BeetleOptimiser",
  "bugs": "https://github.com/ORCHORDS/BeetleOptimiser/issues",
  "author": "ORCHORDS.COM <crm@orchords.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@phosphor-icons/react": "2.1.10",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "electron": "39.8.5",
    "electron-builder": "26.15.3",
    "vite": "6.0.7"
  },
  "build": {
    "appId": "com.orchords.beetleoptimiser",
    "productName": "BeetleOptimiser",
    "copyright": "Copyright (c) 2026 ORCHORDS.COM",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Beetle Optimiser",
      "installerHeaderIcon": "build/icon.ico",
      "uninstallDisplayName": "Beetle Optimiser",
      "deleteAppDataOnUninstall": false,
      "license": "LICENSE"
    },
    "files": [
      "main.js",
      "src/preload.js",
      "scripts/**/*",
      "dist/index.html",
      "dist/assets/**/*",
      "build/icon.ico",
      "package.json",
      "!dist/win-unpacked/**"
    ],
    "asarUnpack": [
      "scripts/**/*"
    ]
  }
}
